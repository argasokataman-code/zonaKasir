APP_NAME=zonaKasir
APP_ENV=local
APP_LOCAL=en
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FORWARD_REDIS_PORT=6381
FORWARD_DB_PORT=3307
#APP_CENTRAL_DOMAIN=localhost #ENABLE IF YOU WANT TO USE MULTI TENANT MODE

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=zonakasir
DB_USERNAME=zonakasir
DB_PASSWORD=secret
DB_DATABASE_TESTING=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
UPLOAD_DISK=public
TMP_DISK=tmp
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
FIREBASE_CREDENTIALS=

SELLING_METHOD=normal

SPA_MODE=false
DARK_MODE=false

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ENABLED=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT=https://zonakasir.jogjatourdrive.com/auth/google/callback

WWWUSER=1000
WWWGROUP=1000

# Flip (Disbursement/Payout) Configuration
FLIP_SECRET_KEY=
FLIP_WEBHOOK_TOKEN=
FLIP_BASE_URL=https://bigflip.id/api # Change to big_sandbox_api for sandbox
FLIP_WITHDRAWAL_AUTO_APPROVE_MAX=5000000
FLIP_WITHDRAWAL_SINGLE_ADMIN_MAX=25000000