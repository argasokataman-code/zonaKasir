{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0",
            "memory": 512
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "framework": null,
    "buildCommand": "yarn run build",
    "outputDirectory": "public",
    "installCommand": "yarn install"
}
