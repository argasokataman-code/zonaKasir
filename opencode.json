{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "markfetch": {
      "type": "local",
      "command": ["npx", "-y", "markfetch"],
      "enabled": true,
      "env": {}
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=fojgbgwgtxdmcowmybdl&read_only=true",
      "enabled": true
    },
    "db-pgsql": {
      "type": "local",
      "command": ["node", ".opencode/mcp/db-server.mjs"],
      "enabled": true,
      "env": {
        "DB_TYPE": "pgsql",
        "DB_HOST": "127.0.0.1",
        "DB_PORT": "5432",
        "DB_DATABASE": "zonakasir",
        "DB_USER": "zonakasir",
        "DB_PASSWORD": "secret"
      }
    }
  }
}